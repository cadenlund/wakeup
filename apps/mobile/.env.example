# Mobile env vars consumed via process.env at build time. Expo strips
# the EXPO_PUBLIC_ prefix and inlines the value into the bundle, so
# anything in here ships to the client — DO NOT put secrets here.
# Real secrets (Sentry DSN dev keys, EAS project id) live in EAS
# Secrets / EAS Build env vars instead.
#
# How env loading actually works:
#
# 1. EAS Build (production builds): each profile in eas.json has its
#    own `env` block — that's the source of truth for builds. The
#    profile values override anything below.
# 2. Local dev (`just mobile-dev` / `just mobile-tunnel`): Expo loads
#    `.env.local` (gitignored) > `.env.<environment>` > `.env`.
#    Copy this file to `.env.local` to override URLs without touching
#    the eas.json profiles.
#
# Defaults below match the `development` profile in eas.json.

EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:8080
EXPO_PUBLIC_ENV=development

# Optional — left blank by default; set to enable Sentry capture in
# local dev. Production builds inject the real DSN via EAS Secrets.
EXPO_PUBLIC_SENTRY_DSN=
